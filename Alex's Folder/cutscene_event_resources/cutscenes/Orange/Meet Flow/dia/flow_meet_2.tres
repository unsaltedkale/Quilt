[ext_resource type="Script" uid="uid://owus6erkinoy" path="res://Resources/Dialogue.gd" id="1_xfv2m"]

[resource]
script = ExtResource("1_xfv2m")
text = Dictionary[String, String]({
"0": "???: So you finally woke up from your nap and crawled out of the wreck you’ve made.",
"1": "QUILT: …",
"10": "???: Leave them to *rot*, little spark.",
"11": "[ QUILT’s hands are shaking.]",
"12": "QUILT: …",
"13": "???: Oh, you won’t?",
"14": "???: I knew you didn’t have a spine because you didn’t break one when you fell.",
"15": "???: Have fun summoning the apocalypse again.",
"16": "",
"2": "???: You can’t even speak? Hah! A classic.",
"3": "???: I’ll keep it brief since you’re in *such* a rush.",
"4": "???: I am going to dismantle you. Piece by piece.",
"5": "???: And once you are nothing, this world will finally be sane again.",
"6": "[ QUILT’s body is not moving. ]",
"7": "???: Hah. If you won’t speak, I’ll tell them.",
"8": "???: Little spark? Your *friend* here caused this whole mess.",
"9": "???: I don’t know why they couldn’t possibly spit that out!"
})
metadata/_custom_type_script = "uid://owus6erkinoy"
