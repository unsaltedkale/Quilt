[ext_resource type="Script" uid="uid://owus6erkinoy" path="res://Resources/Dialogue.gd" id="1_epyi5"]

[resource]
script = ExtResource("1_epyi5")
text = Dictionary[String, String]({
"0": "???: Oh. You’ve reached the end of the trail, haven’t you? The little spark can’t run anymore.",
"1": "???: PYRA please…",
"10": "PYRA: LADY PYRA, spark.",
"11": "",
"2": "PYRA: That is LADY PYRA to you, spark.",
"3": "PYRA: This is what you always do. You disrespect me, spit on me, and then beg for forgiveness after.",
"4": "PYRA: I’m sick of it. I’m sick of you.",
"5": "???: P-PYRA…",
"6": "PYRA: Shut up. You want to see the outside world *sooooo* badly? Do you want to see how it treats your rotten attitude?",
"7": "PYRA: You need to go on your little journey so desperately?",
"8": "PYRA: Go. I don’t care. I’ve given enough to you.",
"9": "???: Wait, no PYRA– no no no–"
})
metadata/_custom_type_script = "uid://owus6erkinoy"
