[gd_resource type="Resource" script_class="DialogResource" load_steps=2 format=3 uid="uid://da3u5eyp7syyp"]

[ext_resource type="Script" uid="uid://owus6erkinoy" path="res://Resources/Dialogue.gd" id="1_d5a78"]

[resource]
script = ExtResource("1_d5a78")
text = Dictionary[String, String]({
"0": "%phlo_surprise%PHLO: Woah!",
"1": "%quilt_neutral%QUILT: ( This is what I was looking for. )",
"10": "%quilt_neutral%[ QUILT is trying to hide their apprehension. They are not doing a good job. ]",
"11": "%quilt_neutral%QUILT: ( Of course. )",
"12": "%quilt_neutral%QUILT: ( The first line says: I KNEW YOU COULD MAKE IT. )",
"13": "%quilt_neutral%QUILT: ( The next line says: I HOPE THEY’RE KIND. OR MAYBE YOU FOUND A WAY OUT OF IT, CLEVER ONE? )",
"14": "%quilt_neutral%QUILT: ( The last line says: FALL, AND THE NET WILL APPEAR. )",
"15": "%phlo_surprise%PHLO: What does it mean?",
"16": "%quilt_neutral%QUILT: ( Notes, from the spirits who made it. )",
"17": "%phlo_neutral%PHLO: But *what* does it mean? What are they saying, really?",
"18": "%quilt_neutral%[ QUILT seems to be considering something. ]",
"19": "%quilt_neutral%QUILT: ( …Encouragement. )",
"2": "%empty%[ There is WHITE glowing markings projected in the air. ]",
"20": "%phlo_surprise%PHLO: Do you know what it really means? Is it addressed to you? Who are the spirits who made it—?",
"21": "%quilt_neutral%QUILT: ( We need to keep moving. )",
"22": "%phlo_surprise%PHLO: QUILT, come on—",
"23": "%quilt_neutral%QUILT: ( You wanted to get of here, correct? )",
"24": "%phlo_worry%[ PHLO is on edge. ]",
"25": "%phlo_neutral%PHLO: …Okay.",
"26": "",
"3": "%quilt_neutral%[ Both great sadness and happiness is overflowing from QUILT’s mind. ]",
"4": "%phlo_neutral%PHLO: Does it say anything?",
"5": "%quilt_neutral%[ QUILT’s mind stutters. ]",
"6": "%quilt_neutral%QUILT: ( Oh. You can’t read it. )",
"7": "%phlo_worry%PHLO: …",
"8": "%phlo_neutral%PHLO: Could you read it to me?",
"9": "%quilt_neutral%QUILT: ( … )"
})
metadata/_custom_type_script = "uid://owus6erkinoy"
