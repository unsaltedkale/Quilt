text = Dictionary[String, String]({
"0": "???: What was I thinking— I’ll never find my way out of here…",
"1": "???: I’ll suffocate in here and no one will care…",
"2": "???: …",
"3": "[ ??? has a growing pit in their stomach. ]",
"4": "???: If… if you can hear me… whoever you were in life…",
"5": "???: Don’t let me go out like this…",
"6": ""
})
